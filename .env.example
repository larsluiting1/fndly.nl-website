# Copy to .env.local for local `vercel dev` testing.
# In production, set this in the Vercel project's Environment Variables instead.

# Resend API key — create one at https://resend.com/api-keys
RESEND_API_KEY=

# Must be an address on a domain you've verified in Resend (Domains tab).
# Until fndly.nl is verified there, sending to lead addresses will fail.
REPORT_FROM_EMAIL=FNDLY <reports@fndly.nl>

# Where new leads get sent for follow-up.
NOTIFY_EMAIL=hello@fndly.nl
